          </li>
          <li>
            <a href="https://linkedin.com/in/rithish-janjeerapu-562a0229a" target="_blank">💼 LinkedIn</a>
          </li>
          <li>
            <a href="mailto:rithishjanjeerapu007@email.com">✉️ Email</a>
          </li>
          <li>
            <a href="https://twitter.com/yourusername" target="_blank">🐦 Twitter</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
<%- include("footer"); -%>
</body>
</html>
