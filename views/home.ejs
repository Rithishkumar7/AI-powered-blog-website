<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
</head>
<body>
<%- include("header"); -%>
<div class="container main-content">
  <h1>Home</h1>
  <p><%= homes %></p>
  <div class="blog-container">
    <% for (let i = 0; i<posts.length; i++) { %>
      <div class="card">
        <div class="card-header">
          <div class="category-badge">
            <span class="category-tag" data-category="<%= posts[i].category %>"><%= posts[i].category %></span>
          </div>
          <h2>
            <span class="post-index"><%= i + 1 %>.</span>
            <%= posts[i].name %>
          </h2>
        </div>
        <div class="card-body">
          <p>
            <%= posts[i].description.substring(0, 100) + "..." %>
            <a href="/posts/<%= posts[i]._id %>">Read more</a>
          </p>
        </div>
      </div>
    <% } %>
  </div>
  <div style="text-align:center; margin-top: 32px;">
    <a href="/compose"><button class="theme-toggle">Write a New Blog</button></a>
  </div>
</div>
<%- include('footer'); -%>
</body>
</html>
